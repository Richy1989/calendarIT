# Copy to .env and adjust. Used by docker-compose.

# --- Database ---
POSTGRES_DB=calendarit
POSTGRES_USER=calendarit
POSTGRES_PASSWORD=changeme

# --- Auth (REQUIRED) ---
# Must be at least 32 characters. Generate a strong random value, e.g.:
#   openssl rand -base64 48
JWT_SIGNING_KEY=
JWT_ISSUER=calendarit
JWT_AUDIENCE=calendarit

# --- Email reminders (optional) ---
# Leave SMTP_HOST blank to log reminders instead of sending them.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=calendarit@localhost
SMTP_USE_SSL=false
