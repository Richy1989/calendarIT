# Copy to .env and adjust. Used by docker-compose.

# --- Database ---
POSTGRES_DB=calendarit
POSTGRES_USER=calendarit
POSTGRES_PASSWORD=changeme

# --- Auth (REQUIRED) ---
# Must be at least 32 characters. Generate a strong random value, e.g.:
#   openssl rand -base64 48
JWT_SIGNING_KEY=
JWT_ISSUER=calendarit
JWT_AUDIENCE=calendarit

# --- Email ---
# There are no SMTP settings here. Email (invitations and reminders) is sent through each
# user's own mail account, connected in the app under Settings → Email. When a user hasn't
# connected one, their reminders are logged instead of sent.
