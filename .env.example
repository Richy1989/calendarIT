# Copy to .env and adjust. Used by docker-compose.

# --- Database ---
POSTGRES_DB=calendarit
POSTGRES_USER=calendarit
POSTGRES_PASSWORD=changeme

# --- Auth (REQUIRED) ---
# Must be at least 32 characters. Generate a strong random value, e.g.:
#   openssl rand -base64 48
JWT_SIGNING_KEY=
JWT_ISSUER=calendarit
JWT_AUDIENCE=calendarit
